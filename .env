# NinjaTrader API Configuration

# Connection mode: 'local' (desktop add-on) or 'cloud' (ecosystem API)
NINJATRADER_MODE=local

# Local Desktop Connection
# NinjaTrader Desktop must be running with the NinjaScript Add-On server
NINJATRADER_LOCAL_URL=http://localhost:7890

# Cloud/Ecosystem API (if using cloud mode)
# NINJATRADER_API_KEY=your_api_key_here
